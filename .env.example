# ── Required ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
META_WEBHOOK_VERIFY_TOKEN=        # any string you choose; paste the same value in the Meta webhook config
META_APP_SECRET=                  # Meta App Dashboard → App settings → Basic → App secret (enables signature verification)
META_ACCESS_TOKEN=                # bootstrap long-lived IG token (per-client tokens in the clients table take precedence)
RESEND_API_KEY=

# ── Recommended ──────────────────────────────────────────────────────────────
ALERT_EMAIL=pedro@arizn.co        # fallback destination for hot lead + ops alerts
RESEND_FROM=ARIZN <alerts@arizn.co>
CRON_SECRET=                      # protects /api/cron/* — Vercel sends it automatically as a Bearer token

# ── Optional ─────────────────────────────────────────────────────────────────
LOG_VERBOSE=false                 # true = log full payloads and DM content (debug only)
REPLY_TEST_SECRET=                # enables POST /api/reply (test endpoint); unset = endpoint disabled
BRAIN_API_URL=                    # ARIZN Brain events endpoint; unset = integration off
BRAIN_AUTH_TOKEN=
GRAPH_API_VERSION=v23.0           # override without redeploying code
